{
    "Version": "2012-10-17",
    "Statement": [
        {
            "Sid": "PublicReadForPropertyImages",
            "Effect": "Allow",
            "Principal": "*",
            "Action": "s3:GetObject",
            "Resource": "arn:aws:s3:::remmic-assets/properties/*"
        },
        {
            "Sid": "PublicReadForPublicAssets",
            "Effect": "Allow",
            "Principal": "*",
            "Action": "s3:GetObject",
            "Resource": "arn:aws:s3:::remmic-assets/public/*"
        }
    ]
}
