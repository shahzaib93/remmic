{
    "CORSRules": [
        {
            "ID": "RemmicCORS",
            "AllowedOrigins": [
                "http://localhost:3008",
                "http://localhost:3000",
                "https://remmic.com",
                "https://*.remmic.com",
                "https://www.remmic.com"
            ],
            "AllowedMethods": [
                "GET",
                "PUT",
                "POST",
                "DELETE",
                "HEAD"
            ],
            "AllowedHeaders": [
                "*"
            ],
            "ExposeHeaders": [
                "ETag",
                "x-amz-meta-custom-header",
                "x-amz-server-side-encryption",
                "x-amz-request-id",
                "x-amz-id-2",
                "Content-Length",
                "Content-Type"
            ],
            "MaxAgeSeconds": 3600
        }
    ]
}
